#!/bin/bash

# --- Core Dependencies ---
if ! command -v bc &> /dev/null; then
    echo "Error: 'bc' is not installed. Run: sudo apt install bc"
    exit 1
fi

# --- ASCII Header ---
show_header() {
    echo "  _                     _       _            "
    echo " | |__   __ _ _ __   __| |_ __ | | __ _ _ __ "
    echo " | '_ \ / _' | '_ \ / _' | '_ \| |/ _' | '_ \\"
    echo " | |_) | (_| | | | | (_| | |_) | | (_| | | | |"
    echo " |_.__/ \__,_|_| |_|\__,_| .__/|_|\__,_|_| |_|"
    echo "                         |_|                 "
    echo "----------------------------------------------"
}

# --- Detailed Help Menu ---
show_help() {
    show_header
    echo "USAGE: bandplan [option] [argument]"
    echo ""
    echo "GENERAL DATA FLAGS:"
    echo "  -h, --help      Show this extended help screen"
    echo "  -a              Show ALL primary amateur bands (160m to 70cm)"
    echo "  --hf            Show only HF bands (160m to 10m)"
    echo "  -c              List common Calling Frequencies (Simplex/National)"
    echo "  -e              List Emergency Frequencies (CB Ch9, Marine 16, Aviation, FRS)"
    echo ""
    echo "FREQUENCY LOOKUP:"
    echo "  -f [MHz]        Lookup specific frequency for Mode, Detail, and Privilege"
    echo "                  Example: bandplan -f 146.52"
    echo ""
    echo "WAVELENGTH SPECIFIC FLAGS:"
    echo "  -160, -80, -40  Show specific HF band plan segments"
    echo "  -30, -20, -17  "
    echo "  -15, -12, -10  "
    echo "  -60             Show 60m channelized frequencies"
    echo "  -v              Show VHF (2m and 1.25m/220)"
    echo "  -u, -70         Show UHF (70cm/440)"
    echo "  -g              Show SHF (23cm and 33cm)"
    echo ""
    echo "SPECIAL BANDS:"
    echo "  -630            Show 630m registration and power limits"
    echo "  -2200           Show 2,200m registration requirements"
    echo "----------------------------------------------"
}

# --- Band Plan Data Modules ---
show_2200() { echo "2200m | 135.7 - 137.8 kHz | CW/Data | 1W EIRP Max | Req UTC Reg"; }
show_630()  { echo "630m  | 472 - 479 kHz | CW/Data | 5W ERP Max | Req UTC Reg"; }
show_160()  { echo "160m  | 1.800 - 2.000 MHz | All Modes | Priv: E-A-G"; }
show_80()   { echo "80m   | 3.500 - 4.000 MHz | CW/Data <3.6 | Phone >3.6 | Priv: E-A-G (Tech CW 3.525-3.6)"; }
show_60()   { echo "60m   | USB Ch: 5332, 5348, 5358.5, 5373, 5405 kHz | 100W ERP | Priv: E-A-G"; }
show_40()   { echo "40m   | 7.000 - 7.300 MHz | CW/Data <7.125 | Phone >7.125 | Priv: E-A-G (Tech CW 7.025-7.125)"; }
show_30()   { echo "30m   | 10.100 - 10.150 MHz | CW/Data Only | 200W Max | Priv: E-A-G"; }
show_20()   { echo "20m   | 14.000 - 14.350 MHz | CW/Data <14.15 | Phone >14.15 | Priv: E-A-G"; }
show_17()   { echo "17m   | 18.068 - 18.168 MHz | CW/Data <18.11 | Phone >18.11 | Priv: E-A-G"; }
show_15()   { echo "15m   | 21.000 - 21.450 MHz | CW/Data <21.2 | Phone >21.2 | Priv: E-A-G (Tech CW 21.025-21.2)"; }
show_12()   { echo "12m   | 24.890 - 24.990 MHz | CW/Data <24.93 | Phone >24.93 | Priv: E-A-G"; }
show_10()   { echo "10m   | 28.000 - 29.700 MHz | CW/Data <28.3 | Phone >28.3 | Priv: E-A-G (Tech SSB 28.3-28.5)"; }

# --- Frequency Lookup Engine ---
lookup_freq() {
    local f=$1
    echo "--- iCOM Band Plan Analysis: $f MHz ---"

    if (( $(echo "$f >= 222.0 && $f <= 225.0" | bc -l) )); then
        echo "BAND: 1.25 Meters"
        if (( $(echo "$f < 222.15" | bc -l) )); then echo "MODE: CW/Weak Signal";
        elif (( $(echo "$f >= 223.38 && $f < 223.52" | bc -l) )); then echo "MODE: FM Simplex";
        elif (( $(echo "$f >= 223.52 && $f < 223.64" | bc -l) )); then echo "MODE: Digital";
        elif (( $(echo "$f >= 223.64 && $f < 223.71" | bc -l) )); then echo "MODE: FM Simplex";
        else echo "MODE: FM Repeater"; fi
        [[ $(echo "$f == 223.5" | bc -l) -eq 1 ]] && echo "NOTE: Calling Freq"
        echo "PRIV: T-E-A-G"
    elif (( $(echo "$f >= 144.0 && $f <= 148.0" | bc -l) )); then
        echo "BAND: 2 Meters"
        if (( $(echo "$f < 144.1" | bc -l) )); then echo "MODE: CW Only";
        elif (( $(echo "$f < 144.3" | bc -l) )); then echo "MODE: SSB/Weak Signal";
        elif (( $(echo "$f >= 146.4 && $f < 146.58" | bc -l) )); then echo "MODE: FM Simplex";
        else echo "MODE: Mixed/Repeater"; fi
        [[ $(echo "$f == 146.52" | bc -l) -eq 1 ]] && echo "NOTE: National Calling Freq"
        echo "PRIV: T-E-A-G"
    elif (( $(echo "$f >= 7.0 && $f <= 7.3" | bc -l) )); then
        echo "BAND: 40 Meters"
        if (( $(echo "$f < 7.125" | bc -l) )); then echo "MODE: CW/RTTY/Data";
        elif (( $(echo "$f == 7.171" | bc -l) )); then echo "MODE: SSTV (Image)";
        else echo "MODE: Phone (LSB)"; fi
        echo "PRIV: E-A-G (Tech CW only 7.025-7.125)"

    # --- 30 Meters (10.100 - 10.150 MHz) ---
    elif (( $(echo "$f >= 10.1 && $f <= 10.15" | bc -l) )); then
        echo "BAND: 30 Meters"
        echo "MODE: CW/RTTY/Data Only"
        echo "PRIV: E-A-G (Max 200 Watts)"

    # --- 20 Meters (14.000 - 14.350 MHz) ---
    elif (( $(echo "$f >= 14.0 && $f <= 14.35" | bc -l) )); then
        echo "BAND: 20 Meters"
        if (( $(echo "$f < 14.150" | bc -l) )); then echo "MODE: CW/RTTY/Data";
        elif (( $(echo "$f == 14.230" | bc -l) )); then echo "MODE: SSTV (Image)";
        else echo "MODE: Phone (USB)"; fi
        echo "PRIV: Extra (14.15+), Advanced (14.175+), General (14.225+)"

    # --- 17 Meters (18.068 - 18.168 MHz) ---
    elif (( $(echo "$f >= 18.068 && $f <= 18.168" | bc -l) )); then
        echo "BAND: 17 Meters"
        if (( $(echo "$f < 18.110" | bc -l) )); then echo "MODE: CW/RTTY/Data";
        else echo "MODE: Phone (USB)"; fi
        echo "PRIV: E-A-G"

    # --- 15 Meters (21.000 - 21.450 MHz) ---
    elif (( $(echo "$f >= 21.0 && $f <= 21.45" | bc -l) )); then
        echo "BAND: 15 Meters"
        if (( $(echo "$f < 21.200" | bc -l) )); then echo "MODE: CW/RTTY/Data";
        elif (( $(echo "$f == 21.340" | bc -l) )); then echo "MODE: SSTV (Image)";
        else echo "MODE: Phone (USB)"; fi
        echo "PRIV: Extra (21.2+), Advanced (21.225+), General (21.275+), Tech (CW 21.025-21.2)"

    # --- 12 Meters (24.890 - 24.990 MHz) ---
    elif (( $(echo "$f >= 24.89 && $f <= 24.99" | bc -l) )); then
        echo "BAND: 12 Meters"
        if (( $(echo "$f < 24.930" | bc -l) )); then echo "MODE: CW/RTTY/Data";
        else echo "MODE: Phone (USB)"; fi
        echo "PRIV: E-A-G"

    # --- 10 Meters (28.000 - 29.700 MHz) ---
    elif (( $(echo "$f >= 28.0 && $f <= 29.7" | bc -l) )); then
        echo "BAND: 10 Meters"
        if (( $(echo "$f < 28.3" | bc -l) )); then echo "MODE: CW/RTTY/Data";
        elif (( $(echo "$f < 28.5" | bc -l) )); then echo "MODE: Phone (USB)";
        elif (( $(echo "$f >= 29.3 && $f < 29.51" | bc -l) )); then echo "MODE: Satellite";
        elif (( $(echo "$f >= 29.51" | bc -l) )); then echo "MODE: FM Repeater/Simplex";
        else echo "MODE: Phone (USB)"; fi
        echo "PRIV: T-E-A-G (Tech SSB 28.3-28.5)"
    else
        echo "RESULT: Use specific wavelength flags or check amateur allocations."
    fi
    
}

# --- Main Argument Parsing ---
case "$1" in
    -h|--help) show_help ;;
    -a) show_header; show_160; show_80; show_60; show_40; show_30; show_20; show_17; show_15; show_12; show_10; echo "--- VHF/UHF ---"; echo "2m: 144-148 | 1.25m: 222-225 | 70cm: 420-450" ;;
    --hf) show_header; show_160; show_80; show_60; show_40; show_30; show_20; show_17; show_15; show_12; show_10 ;;
    -f) shift; lookup_freq $1 ;;
    -c) show_header; echo "2m: 146.52 | 1.25m: 223.5 | 70cm: 446.0 | 6m: 52.525" ;;
    -e) show_header; echo "CB Ch 9: 27.065 | Marine Ch 16: 156.8 | Air Guard: 121.5 | FRS Ch 3: 462.6125" ;;
    -160) show_160 ;;
    -80)  show_80  ;;
    -60)  show_60  ;;
    -40)  show_40  ;;
    -30)  show_30  ;;
    -20)  show_20  ;;
    -17)  show_17  ;;
    -15)  show_15  ;;
    -12)  show_12  ;;
    -10)  show_10  ;;
    -v)   show_header; echo "2m: 144-148 MHz"; echo "1.25m: 222-225 MHz" ;;
    -u|-70) show_header; echo "70cm: 420-450 MHz" ;;
    -g)   show_header; echo "33cm: 902-928 MHz"; echo "23cm: 1240-1300 MHz" ;;
    -630) show_630 ;;
    -2200) show_2200 ;;
    *) [[ -z "$1" ]] && show_help || echo "Unknown option. Use -h for help." ;;
esac
